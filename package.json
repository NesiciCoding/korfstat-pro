{
  "name": "korfstat-pro",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "server": "node server/index.js",
    "dev:server": "node server/index.js",
    "dev:multi": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "deploy": "vite build && node scripts/deploy-ftp.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "coverage": "vitest run --coverage",
    "analyze": "vite build && open dist/stats.html",
    "prepare": "husky",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/build.js",
    "tauri:build:mac": "node scripts/build.js --target mac",
    "tauri:build:win": "node scripts/build.js --target win",
    "tauri:build:linux": "node scripts/build.js --target linux",
    "tauri:build:debug": "node scripts/build.js --debug",
    "tauri:build:all": "node scripts/build.js --target all"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "html-to-image": "^1.11.13",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "multer": "^2.1.1",
    "obs-websocket-js": "^5.0.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.5.8",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-react": "5.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.1",
    "ftp-deploy": "^2.4.7",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "react-is": "^19.2.5",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.9.3",
    "vite": "6.1.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "vitest related --run"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
