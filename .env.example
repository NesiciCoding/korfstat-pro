# Environment Variables Template for KorfStat Pro

# ===========================================
# Gemini AI Configuration
# ===========================================
# Get your API key from: https://makersuite.google.com/app/apikey
# This is used for AI-powered match analysis, strategy reports, and live commentary
VITE_GEMINI_API_KEY=your_api_key_here

# ===========================================
# Server Configuration (Optional)
# ===========================================
# WebSocket server port for real-time synchronization
# Default: 3002
# VITE_WS_PORT=3002

# ===========================================
# Supabase Configuration
# ===========================================
# Get your keys from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ===========================================
# FTP Deployment Configuration (Optional)
# ===========================================
# These are used by scripts/deploy-ftp.js
# FTP_HOST=ftp.yourwebsite.com
# FTP_USER=your_username
# FTP_PASSWORD=your_password
# FTP_REMOTE_ROOT=/public_html
